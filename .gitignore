# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.pytest_cache/

# Distribution / Packaging
dist/
build/
*.egg-info/

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Mac
.DS_Store

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Environment Variables (CRITICAL)
.env
.env.local

# Streamlit Secrets (CRITICAL — never commit API keys)
.streamlit/secrets.toml

# Temporary commit message files (generated by our git workflow)
_commit_msg.txt

# Project Specific
_archive/
output/
logs/
temp/
*.log

# Generated images (app writes to BytesIO only, but guard against manual saves)
*.png
*.jpg
*.jpeg

# Downloaded / generated font assets
*.otf
*.ttf
*.woff
*.woff2
*.eot

# Python version manager
.python-version

# Test coverage
.coverage
coverage.xml
htmlcov/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
